{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "wikijs",
      "source": {
        "type": "dockerfile",
        "dockerfilePath": "Dockerfile"
      },
      "settings": {
        "lifecycle": "STARTUP",
        "healthcheckPath": "/ping",
        "restartPolicyType": "ALWAYS",
        "startCommand": "node server/server.js"
      },
      "deploy": {
        "startDelay": 120,
        "healthCheckPath": "/ping",
        "restartPolicyType": "ALWAYS",
        "healthCheckTimeout": 180
      }
    }
  ],
  "source": {
    "type": "dockerfile",
    "dockerfilePath": "Dockerfile"
  }
}