# =============================================================================
# Wiki.js 2.x — Self-hosted Knowledge Base & Documentation Platform
# https://docs.requarks.io/i/getting-started/install/prerequisites/docker
# =============================================================================

# ---------------------------------------------------------------------------
# Database Configuration
# Wiki.js supports PostgreSQL, MySQL/MariaDB, SQL Server, and SQLite.
# For Railway: use PostgreSQL (recommended) or leave empty for SQLite.
# ---------------------------------------------------------------------------

# Database engine: postgres, mysql, mssql, sqlite (required)
DB_TYPE=postgres

# PostgreSQL / MySQL connection settings
DB_HOST=db-postgres
DB_PORT=5432
DB_NAME=wikijs
DB_USER=wikijs
DB_PASS=change-me-to-secure-password

# SQLite storage path (when using DB_TYPE=sqlite)
DB_FILEPATH=/wiki/data/wikijs.db

# SQLite fallback (set DB_PATH when using SQLite)
DB_PATH=/config/wikijs.db

# ---------------------------------------------------------------------------
# Server Configuration
# Port Wiki.js listens on. Railway injects PORT automatically.
# ---------------------------------------------------------------------------

PORT=3000

# ---------------------------------------------------------------------------
# Application Settings
# Display name shown in browser tab & UI
# ---------------------------------------------------------------------------

APP_NAME=Wiki.js
TIMEZONE=UTC
URL_BASE=https://your-domain.railway.app
