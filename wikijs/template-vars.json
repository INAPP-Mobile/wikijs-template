{
  "DB_HOST": {
    "defaultValue": "postgres.railway.internal",
    "description": "PostgreSQL database host. Points at the sibling 'Postgres' Railway service.",
    "isOptional": false
  },
  "DB_PORT": {
    "defaultValue": "5432",
    "description": "PostgreSQL database port (default: 5432)",
    "isOptional": true
  },
  "DB_NAME": {
    "defaultValue": "wikijs",
    "description": "Database name for Wiki.js data",
    "isOptional": false
  },
  "DB_USER": {
    "defaultValue": "wikijs",
    "description": "Database user for Wiki.js",
    "isOptional": false
  },
  "DB_PASS": {
    "defaultValue": "${{secret(32)}}",
    "description": "Database password. Auto-generated on first deploy \u2014 you can change it later.",
    "isOptional": false
  },
  "PORT": {
    "defaultValue": "3000",
    "description": "Port Wiki.js listens on (default: 3000)",
    "isOptional": true
  },
  "APP_NAME": {
    "defaultValue": "Wiki.js",
    "description": "Display name for your wiki",
    "isOptional": true
  },
  "TIMEZONE": {
    "defaultValue": "UTC",
    "description": "Server timezone (e.g., America/New_York, Europe/London)",
    "isOptional": true
  },
  "URL_BASE": {
    "defaultValue": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
    "description": "Public URL of your wiki. Auto-populated from Railway's public domain.",
    "isOptional": true
  },
  "DB_TYPE": {
    "defaultValue": "postgres",
    "description": "Database engine: postgres, mysql, mssql, or sqlite (default: postgres)",
    "isOptional": true
  },
  "DB_FILEPATH": {
    "defaultValue": "/wiki/data/wikijs.db",
    "description": "Path for SQLite database file when using DB_TYPE=sqlite",
    "isOptional": true
  }
}
