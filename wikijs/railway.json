{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "wikijs/Dockerfile"
  },
  "deploy": {
    "healthcheckPath": "/ping",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "volumeMounts": [
      {
        "name": "wikijs-data",
        "mountPath": "/wiki/data"
      }
    ]
  }
}
