# ============================================================================
# Coolify on DigitalOcean — Configuration
# Copy to .env and fill in. Never commit .env.
# ============================================================================

# Domain you control — must have wildcard DNS A record → droplet
DOMAIN=yourdomain.com

# DigitalOcean
DO_REGION=nyc3
DO_SIZE=s-2vcpu-4gb              # 4GB / 2 vCPU / $24/mo
DO_IMAGE=ubuntu-24-04-x64
DO_SSH_KEY_FINGERPRINT=          # `doctl compute ssh-key list` — paste here
COOLIFY_DROPLET_NAME=coolify-gallery

# Coolify admin (you'll set this email + password during first-run in the UI)
COOLIFY_ADMIN_EMAIL=admin@${DOMAIN}
COOLIFY_ADMIN_PASSWORD=          # 32+ chars; generate with `openssl rand -base64 24`

# Coolify API token — created in the UI after install:
#   Coolify UI → Settings → API Tokens → Create
COOLIFY_API_TOKEN=
COOLIFY_BASE_URL=https://coolify.${DOMAIN}/api/v1

# Per-service subdomain prefixes (gets prepended to DOMAIN)
GOTIFY_SUBDOMAIN=gotify
MEMOS_SUBDOMAIN=memos
KANBOARD_SUBDOMAIN=kanboard
NETDATA_SUBDOMAIN=netdata
STIRLING_SUBDOMAIN=pdf
NODERED_SUBDOMAIN=flows

# Per-service-internal ports (must match the port the app actually listens on)
GOTIFY_PORT=8080
MEMOS_PORT=5230
KANBOARD_PORT=80
NETDATA_PORT=19999
STIRLING_PORT=8080
NODERED_PORT=1880

# DO Managed Postgres (shared by Memos + Kanboard)
PG_DROPLET_NAME=coolify-pg
# Optional: skip managed PG and use local Postgres in Coolify (free)
USE_LOCAL_POSTGRES=true
