# ============================================================================
# Kanboard — Coolify service env vars
# Project management. Defaults to SQLite (built-in via the base image).
# ============================================================================

# Kanboard listens on this port internally; Traefik fronts it on
# ${KANBOARD_SUBDOMAIN}.${DOMAIN}:443
# The Railway template uses port 80 — DO Coolify matches that.
KANBOARD_PORT=80

# Application URL (used for password-reset links etc.)
# NOTE: Coolify imports .env files as literal text — shell variables DO NOT expand.
# Defaults to Traefik host auto-detect by leaving this UNSET. Kanboard auto-detects
# the Host header when APP_URL is empty, which is correct behind Coolify's proxy.
# Set this only if you've moved Kanboard to a custom domain not managed by Traefik:
# APP_URL=https://your-explicit-domain.example.com

# Session-related overrides (optional)
# SESSION_COOKIE_LIFETIME=2592000
# DISABLE_CUSTOM_PROJECTS=false

# Default timezone for new users
DEFAULT_TIMEZONE=UTC

# Default language
DEFAULT_LANGUAGE=en_US

# Enable/disable user self-registration
ENABLE_USER_REGISTRATION=false

# Persistent Kanboard data path — already the default inside base image.
# Coolify will mount a volume at /var/www/app/data automatically if you
# add a Storage entry in the UI (recommended for SQLite).
DATA_DIR=/var/www/app/data
