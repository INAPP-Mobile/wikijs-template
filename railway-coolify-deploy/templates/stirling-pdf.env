# ============================================================================
# Stirling-PDF — Coolify service env vars
# Java/Spring-Boot-based PDF manipulation toolkit. Heavy on first build
# (≈ 5 min) but fast after Docker layer cache warms.
# ============================================================================

# Spring Boot HTTP port (must match Dockerfile EXPOSE)
PORT=8080

# Server timezone
TZ=UTC

# Authentication is ENABLED by default in the docker image.
# Change DEFAULT_ADMIN_PASSWORD either at first boot or via Coolify:
DEFAULT_ADMIN_PASSWORD=CHANGEME-strong-password-here

# UI customization (optional)
# DISABLE_ADDITIONAL_FEATURES=false  # enables premium endpoints
# SECURITY_INITIAL_LOGIN=admin
# SECURITY_ENABLELOGIN=true

# Set security headers (recommended)
SECURITY_ENABLE_CONTENT_SECURITY_POLICY=true
SECURITY_ENABLE_CSP=true
SECURITY_ENABLE_HSTS=true

# Reduce log noise — uses SLF4j at INFO level by default
LOGGING_LEVEL_ROOT=INFO
