# ============================================================================
# Memos — Coolify service env vars
# Single user notes app. Defaults to SQLite; flip DSN to use Postgres.
# ============================================================================

# HTTP listen port (must match Dockerfile EXPOSE)
MEMOS_PORT=5230

# Database: leave blank to use SQLite at /var/opt/memos/memos_prod.db
# To use Postgres, set:
#   MEMOS_DSN=postgres://memos:****@<pg-host>:25060/memos?sslmode=require
# (Coolify managed DB exposes DATABASE_URL automatically)
MEMOS_DSN=

# Server timezone
TZ=UTC

# Log verbosity — debug/Info/Warn/Error
MEMOS_LOG_LEVEL=info

# Optional: pre-create admin on first launch.
# Both must be set together. AFTER first launch, leave these unset
# (Memos ignores them on subsequent boots).
MEMOS_ADMIN_EMAIL=
MEMOS_ADMIN_PASSWORD=
