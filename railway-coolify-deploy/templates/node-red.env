# ============================================================================
# Node-RED — Coolify service env vars
# Low-code IoT / automation editor. Persists /data via Coolify volume mount.
# ============================================================================

# Internal HTTP port (must match Dockerfile EXPOSE)
NODE_RED_PORT=1880

# Timezone
TZ=UTC

# Disable project structure (simpler default; re-enable for team flows)
NODE_RED_ENABLE_PROJECTS=false

# Disable safe mode (startup flows must always run)
NODE_RED_ENABLE_SAFE_MODE=false

# Credentials secret — used to encrypt the flows file on disk
# IMPORTANT: set to a stable value (32+ chars) so flows are still
# readable after a redeploy with mounted volume.
NODE_RED_CREDENTIALS_SECRET=CHANGEME-32-char-random-string-here

# Default flow file location (in /data volume mount)
FLOWS=flows.json
