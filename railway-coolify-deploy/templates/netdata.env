# ============================================================================
# Netdata — Coolify service env vars
# Real-time infrastructure monitoring. Mounts host /proc + /sys via DO
# in the Coolify storage tab to monitor the Droplet's own metrics.
# ============================================================================

# Netdata listens on this port internally.
# NOTE: The upstream Dockerfile bakes NETDATA_LISTENER_PORT=$NETDATA_PORT at
# *build* time, but Coolify injects env at *runtime*. Setting both here so the
# runtime container advertises the same port to its API.
NETDATA_PORT=19999
NETDATA_LISTENER_PORT=19999

# Cloudflare DNS (avoid Google DNS which has been unreliable in DO regions)
NETDATA_DNS=1.1.1.1

# Don't allow unauthenticated dashboard access by default;
# set to true if you want a public demo
NETDATA_ENABLE_WEB_REDIRECT=false
NETDATA_WEB_ALLOW_CONNECT_FROM=*

# Disable email-based notifications (we don't have anyone to send to)
NETDATA_SEND_DISABLED_ALARMS_TO_NEW_MEMBERS=false

# Optional: pin a parent registry to share monitoring dashboards with friends
# - Generate via the Netdata UI → Sign in → Cloud → Get a claim token
# NETDATA_REGISTRY_CLAIM_TOKEN=
# NETDATA_REGISTRY_URL=https://registry.my-netdata.io
