# ============================================================================
# Gotify — Coolify service env vars
# Applied at deploy time by register-services.sh → Coolify API
# ============================================================================

# Bind port (Coolify Traefik fronts this on ${GOTIFY_SUBDOMAIN}.${DOMAIN}:443)
GOTIFY_SERVER_PORT=8080

# Listen on all interfaces inside the container
GOTIFY_SERVER_BINDADDRESS=0.0.0.0

# First-run credentials (change after first login via the web UI)
GOTIFY_DEFAULTUSER_NAME=admin
GOTIFY_DEFAULTUSER_PASS=CHANGEME-strong-password-here

# Default to SQLite (single-file). To use Postgres, set:
#   GOTIFY_DATABASE_DIALECT=postgres
#   GOTIFY_DATABASE_CONNECTION=<your DO managed DB url>
# and provision the DB in Coolify → Service → Add Database.
GOTIFY_DATABASE_DIALECT=sqlite3
GOTIFY_DATABASE_CONNECTION=data/gotify.db

# Lock down public registration
GOTIFY_REGISTRATION=false

# Logging
GOTIFY_SERVER_LOG_LEVEL=info

# Upload limits
GOTIFY_FILE_SIZE=20
GOTIFY_UPLOADEDIMAGES_DIR=data/images
